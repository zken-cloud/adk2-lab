# ADK 2.0 Environment Configuration
# Copy this file to .env and update with your values:
#   cp .env.example .env

# Use Vertex AI as the backend (required for ADC-based auth)
GOOGLE_GENAI_USE_VERTEXAI=1

# Your GCP project ID
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Vertex AI location (use "global" for global endpoint)
GOOGLE_CLOUD_LOCATION=global
